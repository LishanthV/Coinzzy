# Coinzy Backend Configuration Template
# Copy this file to '.env' and fill in your values.
# IMPORTANT: Never commit the actual '.env' file containing secrets/credentials to Git!

# Server port configuration
PORT=5000

# Database Configuration (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_secure_db_password
DB_NAME=coinzy_db
DB_PORT=3306

# JSON Web Token (JWT) Secrets
# IMPORTANT: Set strong, unique keys in production.
# Recommended: Use `openssl rand -base64 32` to generate secure secrets.
JWT_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me

# SMTP / Email Configuration (e.g. for Gmail)
# For Gmail, generate an App Password in your Google Account Security settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Coinzy" <your_gmail_address@gmail.com>
BACKEND_URL=http://localhost:5000

