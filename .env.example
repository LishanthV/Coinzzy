# Coinzy Frontend Environment Configuration Template
# Copy this file to '.env' and fill in your values.
# IMPORTANT: Never commit the actual '.env' file containing secrets/IPs to Git!

# Backend API URL
# - For Local Web development: http://localhost:5000
# - For Android Emulator: http://10.0.2.2:5000
# - For iOS Simulator: http://localhost:5000
# - For Physical Devices: Use your machine's local network IP address (e.g., http://192.168.1.100:5000)
EXPO_PUBLIC_BACKEND_URL=http://localhost:5000

# Supabase Credentials (Optional - Falls back to demo/local storage mock if omitted)
# EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
